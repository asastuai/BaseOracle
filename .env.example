# ============================================
# BASEORACLE — Environment Variables
# ============================================
# Copy this to .env and fill in your values

# --- YOUR WALLET ---
# Private key of the wallet that receives x402 payments AND deploys the token
# NEVER commit this to git
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Public address of the wallet above (used as payTo in x402)
PAY_TO_ADDRESS=0xYOUR_PUBLIC_ADDRESS_HERE

# --- NETWORK ---
BASE_RPC_URL=https://mainnet.base.org

# --- API KEYS ---
# Basescan: get free key at https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_KEY

# Clanker: get API key at https://clanker.world (for token deploy)
CLANKER_API_KEY=YOUR_CLANKER_KEY

# --- x402 ---
# Coinbase CDP facilitator (free on Base mainnet)
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# --- USDC ON BASE MAINNET ---
# Don't change this
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# --- SERVER ---
PORT=3000
NODE_ENV=production

# --- CACHE ---
# Cache TTL in seconds (how fresh the data is)
CACHE_TTL_PRICES=30
CACHE_TTL_TRENDING=60
CACHE_TTL_WHALES=15

# --- PROOF-OF-CONTEXT (PoC) ATTESTATION ---
# Generate with: node scripts/gen-poc-key.js
# If unset, paid responses are returned without signature (still informational).
POC_SIGNING_KEY=
POC_SOURCE_ID=baseoracle:default

# --- POC TRIPLE-ANCHOR (optional) ---
# Set to "1" to populate anchors.block_height + anchors.drand_round on every
# attestation. Without it, those fields are null and the attestation falls
# back to the server timestamp as the only binding clock.
POC_ENABLE_TRIPLE_ANCHOR=
# Optional overrides. Defaults are reasonable.
POC_DRAND_URL=https://drand.cloudflare.com
POC_BASE_RPC_URL=https://mainnet.base.org

# --- CORS ---
# Comma-separated list of origins allowed to call the API. If unset, CORS is
# wide-open (useful for dev and curl tooling). For production, restrict.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://agent.example.com
CORS_ALLOWED_ORIGINS=
